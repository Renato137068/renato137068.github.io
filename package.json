{
  "name": "financaspro-v11",
  "version": "11.0.0",
  "description": "FinançasPro — SaaS de Finanças Pessoais",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci",
    "test:unit": "jest --testPathPattern=tests/ --verbose",
    "test:open-coverage": "jest --coverage && start coverage/lcov-report/index.html",
    "lint": "eslint js/ --ext .js",
    "dev": "vite",
    "dev:legacy": "http-server . -p 3000 -g",
    "build": "vite build --config vite.config.cjs",
    "build:analyze": "vite build --config vite.config.cjs --mode analyze",
    "preview": "vite preview",
    "backend": "node backend/server.js",
    "backend:dev": "node --watch backend/server.js",
    "start": "vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node backend/prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "worker": "node backend/workers/index.js",
    "worker:dev": "node --watch backend/workers/index.js",
    "billing:seed": "node backend/prisma/seed-plans.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "vendor:sync": "node scripts/sync-vendor.js",
    "postinstall": "node scripts/sync-vendor.js"
  },
  "keywords": [
    "finanças",
    "pessoais",
    "saas",
    "pwa",
    "javascript"
  ],
  "author": "Renato José Soares",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide": "^1.14.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "terser": "^5.24.0",
    "vite": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/tests/setup-globals.js"
    ],
    "transform": {},
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/core/utils.js",
      "js/core/validations.js",
      "js/score.js",
      "js/parser.js",
      "js/core/store.js",
      "js/orcamento.js",
      "js/transacoes.js",
      "js/pipeline.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 0,
        "functions": 0,
        "branches": 0
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
